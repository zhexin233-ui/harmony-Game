<template>
	<view class="game-card" :class="{ disabled: disabled }" :style="cardStyle" @tap="onTap">
		<view class="cover" :style="coverStyle">
			<image
				v-if="coverMode === 'image'"
				class="cover-image"
				:src="cover"
				mode="aspectFit"
				@error="onImageError"
			/>
			<UiIcon v-else class="cover-icon" :name="fallbackIconKey" :size="56" :opacity="disabled ? 0.56 : 1" />
			<view class="players-pill" :style="pillStyle">
				<text class="players-text" :style="pillTextStyle">{{ min }}-{{ max }} 人</text>
			</view>
		</view>
		<text class="game-name" :style="nameStyle">{{ name }}</text>
		<text class="game-summary" :style="summaryStyle">{{ disabledReason || summary }}</text>
	</view>
</template>

<script setup lang="uts">
	import { computed, ref } from 'vue'
	import UiIcon from '@/components/UiIcon.uvue'
	import { useSettings } from '@/stores/settings'
	import { themes } from '@/theme/tokens'
	import type { IconKey } from '@/ui/icons'

	const props = defineProps<{
		id : string
		name : string
		summary : string
		fallbackIconKey : IconKey
		cover : string
		min : number
		max : number
		disabled ?: boolean
		disabledReason ?: string
		cardWidth ?: string
		coverSize ?: string
	}>()

	const emit = defineEmits<{
		(e : 'tap') : void
		(e : 'imageError', id : string) : void
	}>()

	const settings = useSettings()
	const tokens = computed(() => themes[settings.theme])
	const imageFailed = ref(false)

	const coverMode = computed(() => imageFailed.value || props.cover.length === 0 ? 'icon' : 'image')

	const cardStyle = computed(() => ({
		backgroundColor: tokens.value.cardBg,
		boxShadow: tokens.value.shadowSoft,
		opacity: props.disabled ? 0.56 : 1,
		width: props.cardWidth ?? '48%'
	}))
	const coverStyle = computed(() => ({
		backgroundColor: props.disabled ? tokens.value.disabledBg : tokens.value.imageCardBg,
		height: props.coverSize ?? '168px'
	}))
	const pillStyle = computed(() => ({
		backgroundColor: tokens.value.success
	}))
	const pillTextStyle = computed(() => ({
		color: tokens.value.onSecondary
	}))
	const nameStyle = computed(() => ({
		color: tokens.value.primary
	}))
	const summaryStyle = computed(() => ({
		color: props.disabled ? tokens.value.dangerText : tokens.value.textMuted
	}))

	function onTap() {
		if (props.disabled) return
		emit('tap')
	}

	function onImageError() {
		imageFailed.value = true
		emit('imageError', props.id)
	}
</script>

<style>
	.game-card {
		min-height: 220px;
		border-radius: 26px;
		padding: 10px;
		margin-bottom: 14px;
		align-items: center;
		flex-shrink: 0;
	}
	.cover {
		position: relative;
		width: 100%;
		border-radius: 20px;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}
	.cover-image {
		width: 100%;
		height: 100%;
	}
	.players-pill {
		position: absolute;
		right: 8px;
		top: 8px;
		border-radius: 14px;
		padding: 3px 8px;
	}
	.players-text {
		font-size: 11px;
		font-weight: bold;
	}
	.game-name {
		margin-top: 10px;
		font-size: 17px;
		font-weight: 800;
		text-align: center;
	}
	.game-summary {
		margin-top: 4px;
		font-size: 12px;
		text-align: center;
		line-height: 17px;
	}
	.disabled {
		filter: grayscale(20%);
	}
</style>
